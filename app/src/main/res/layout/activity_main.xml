<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/appBackground">

    <!-- Toolbar for title + 3-dot menu -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarMain"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- Recent chats title -->
    <TextView
        android:id="@+id/textRecentChatsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recent chats"
        android:textColor="@color/colorSecondary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <!-- Recent chats list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRecentChats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:contentDescription="Recent chats list" />

    <!-- Bottom menu: Contacts, Logout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center">

        <!-- Proceed button -->
        <Button
            android:id="@+id/buttonContacts"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Contacts"
            android:textColor="@color/colorWhite"
            android:background="@drawable/button_proceed"
            android:layout_marginEnd="10dp" />

        <!-- Reverted / outline button -->
        <Button
            android:id="@+id/buttonLogout"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Logout"
            android:textColor="@color/colorSecondary"
            android:background="@drawable/button_reverted"
            android:layout_marginStart="10dp" />

    </LinearLayout>

</LinearLayout>
