<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutContactsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/appBackground"
    android:padding="16dp">

    <!-- Top bar: Add Contact + Contact Requests -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:paddingBottom="12dp">

        <!-- Add Contact button (proceed) -->
        <Button
            android:id="@+id/buttonAddContact"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Add Contact"
            android:textColor="@color/colorWhite"
            android:background="@drawable/button_proceed"
            android:layout_marginEnd="8dp" />

        <!-- Contact Requests button (outline) -->
        <Button
            android:id="@+id/buttonContactRequests"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Contact Requests"
            android:textColor="@color/colorSecondary"
            android:background="@drawable/button_reverted"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Contacts list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
