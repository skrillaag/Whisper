<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Transparent fill to blend with dark background -->
    <solid android:color="@android:color/transparent" />

    <!-- Subtle border using your secondary text color -->
    <stroke
        android:width="1dp"
        android:color="@color/textSecondary" />

    <!-- Rounded corners -->
    <corners android:radius="8dp" />

    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />
</shape>
